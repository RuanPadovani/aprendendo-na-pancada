{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=YourDatabase;Uid=root;Pwd=YourPassword"
  },
  "JWT": {
    "ValidAudiences": "http://localhost:5182",
    "ValidIssuer": "https://localhost:7179",
    "SecretKey": "YOUR_SECRET_KEY_HERE_MIN_32_CHARACTERS",
    "TokenValidMinutes": 15,
    "RefreshTokenValidInMinutes": 120
  }
}